# Arquivo de exemplo de variáveis de ambiente para o projeto Django.
# Copie para .env e ajuste os valores em produção.

# Configurações Django
DJANGO_SECRET_KEY=your-secret-key-aqui
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (padrão sqlite em dev)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=

# Auth/Token
#TOKEN_SECRET=... (se precisar em uma camada extra)

# URLs de documentação
#SWAGGER_URL=http://localhost:8000/swagger/
